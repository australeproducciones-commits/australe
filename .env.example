NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# URL pública del sitio (desarrollo: http://localhost:3000). Usada para QR de ventas y back_urls de Mercado Pago.
NEXT_PUBLIC_SITE_URL=

# Mercado Pago Checkout Pro (solo servidor salvo Public Key)
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=
# test | production
MERCADOPAGO_ENVIRONMENT=test
# Habilita checkout MP en Tienda (backend también valida)
MERCADOPAGO_ENABLED=false
# Habilita pago en caja / confirmación manual en checkout
STORE_MANUAL_PAYMENT_ENABLED=true
# Secreto para /api/cron/expire-store-reservations (Vercel Cron envía Bearer)
CRON_SECRET=
