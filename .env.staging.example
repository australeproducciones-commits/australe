# Staging — pagos híbridos (NO commitear valores reales)
# Copiar a .env.staging.local y completar tras crear el proyecto australe-staging-hybrid

STAGING_SUPABASE_PROJECT_ID=
STAGING_SUPABASE_DB_PASSWORD=
STAGING_SUPABASE_URL=
STAGING_SUPABASE_ANON_KEY=
STAGING_SUPABASE_SERVICE_ROLE_KEY=

# Alias usados por scripts de la app
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Provision / Management API (solo local o CI)
SUPABASE_ACCESS_TOKEN=

STAGING_SEED_TAG=hybrid-v1

# Preview Vercel (rama feat/store-hybrid-payments)
NEXT_PUBLIC_SITE_URL=
MERCADOPAGO_ENABLED=false
STORE_MANUAL_PAYMENT_ENABLED=true
MERCADOPAGO_ENVIRONMENT=test
CRON_SECRET=

