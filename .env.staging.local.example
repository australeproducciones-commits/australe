# Variables de staging para validar sorteos (NO commitear valores reales)
# Copiar a .env.staging.local dentro del worktree de sorteos

# Obligatorio para E2E con mutaciones
ALLOW_GIVEAWAY_E2E=true

# Project ref de Supabase staging (hostname: <ref>.supabase.co)
EXPECTED_SUPABASE_PROJECT_REF=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Secreto exclusivo de staging/preview (no reutilizar producción)
CRON_SECRET=
