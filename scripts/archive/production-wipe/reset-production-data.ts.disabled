}

async function rpcAvailable(admin: SupabaseClient): Promise<boolean> {
  const { error } = await admin.rpc("reset_production_transactional_data", {
    p_dry_run: true,
    p_reset_all_loyalty: false,
  });
  if (error) {
    if (
      error.message.includes("Could not find the function") ||
      error.message.includes("does not exist")
    ) {
      return false;
    }
    throw new Error(`RPC dry-run fallГі: ${error.message}`);
  }
  return true;
}

async function runViaRpc(
  admin: SupabaseClient,
  dryRun: boolean,
  resetAllLoyalty: boolean,
): Promise<Record<string, unknown>> {
  const { data, error } = await admin.rpc("reset_production_transactional_data", {
    p_dry_run: dryRun,
    p_reset_all_loyalty: resetAllLoyalty,
  });
  if (error) {
    throw new Error(`RPC reset fallГі: ${error.message}`);
  }
  return (data ?? {}) as Record<string, unknown>;
}

async function verifyPostReset(admin: SupabaseClient): Promise<boolean> {
  let ok = true;
  const mustBeZero = [
    "events",
    "ticket_types",
    "tickets",
    "kiosk_products",
    "event_kiosk_products",
    "event_kiosk_settings",
    "kiosk_orders",
    "kiosk_order_items",
    "kiosk_product_stock_movements",
    "event_streams",
    "event_expenses",
    "event_expense_payments",
    "event_other_income",
    "community_event_invitations",
    "cash_closures",
    "analytics_events",
    "advertising_impressions",
  ];

  console.log("\n--- VerificaciГіn posterior ---");
  for (const table of mustBeZero) {
    const count = await countTable(admin, table);
    const pass = count === 0;
    console.log(`${pass ? "вњ“" : "вњ—"} ${table}: ${count ?? "error"}`);
    if (!pass) ok = false;
  }

  const { data: preserved } = await admin.from("profiles").select("id");
  console.log(`вњ“ profiles conservados: ${preserved?.length ?? 0}`);
  const { data: cats } = await admin.from("kiosk_product_categories").select("id");
  console.log(`вњ“ kiosk_product_categories conservadas: ${cats?.length ?? 0}`);

  return ok;
}

async function main(): Promise<void> {
  const args = process.argv.slice(2);
  if (!args.includes("--dry-run") && !process.env.ALLOW_PRODUCTION_RESET) {
    console.error("UsГЎ --dry-run para simular, o ALLOW_PRODUCTION_RESET=true para ejecuciГіn real.");
    process.exit(1);
  }

  const { dryRun, resetAllLoyalty } = parseArgs(args);
  const env = getEnv();
  const { url, serviceKey } = requireEnv(env);

  const admin = createClient(url, serviceKey, {
    auth: { persistSession: false, autoRefreshToken: false },
  });

  console.log("\n=== Reset vaciado completo вЂ” Australe Producciones ===");
  console.log(`Modo: ${dryRun ? "DRY-RUN" : "EJECUCIГ“N REAL"}`);
  console.log(`Supabase: ${url}`);

  if (dryRun) {
    await runDetailedDryRun(admin, resetAllLoyalty);
    const hasRpc = await rpcAvailable(admin);
    if (hasRpc) {
      console.log("RPC instalada вЂ” respuesta JSON adicional:\n");
      const rpcResult = await runViaRpc(admin, true, resetAllLoyalty);
      console.log(JSON.stringify(rpcResult, null, 2));
    } else {
      console.log(
        "в„№ RPC no instalada aГєn. AplicГЎ scripts/sql/reset_production_transactional_data.sql cuando autorices.",
      );
    }
    return;
  }

  assertRealRunAllowed(env);
  const hasRpc = await rpcAvailable(admin);
  if (!hasRpc) {
    console.error("Reset real abortado: aplicГЎ la RPC SQL primero.");
    process.exit(1);
  }

  console.log(`reset_all_loyalty: ${resetAllLoyalty}\n`);
  const result = await runViaRpc(admin, false, resetAllLoyalty);
  console.log(JSON.stringify(result, null, 2));

  const ok = await verifyPostReset(admin);
  if (!ok) process.exit(1);
  console.log("\nReset completado y verificado.");
}

main().catch((err: unknown) => {
  console.error(err);
  process.exit(1);
});
