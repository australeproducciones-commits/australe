/*
 * ARCHIVO HISTУRICO NO EJECUTABLE.
 *
 * Este procedimiento fue utilizado una ъnica vez para eliminar datos de prueba.
 * La RPC destructiva fue eliminada del entorno remoto.
 * No restaurar ni ejecutar este archivo sin una revisiуn de seguridad explнcita.
 */
/**
 * Reset completo: vaciar eventos y productos de prueba antes de producciГіn.
 *
 * Dry-run (sin modificar, no requiere RPC instalada):
 *   npm run reset:production-data -- --dry-run
 *
 * Dry-run + opciГіn fidelizaciГіn total simulada:
 *   npm run reset:production-data -- --dry-run --reset-all-loyalty
 *
 * EjecuciГіn real:
 *   ALLOW_PRODUCTION_RESET=true RESET_CONFIRMATION=RESET-AUSTRALE-PRODUCCION npm run reset:production-data
 *
 * EjecuciГіn real + vaciar fidelizaciГіn:
 *   ALLOW_PRODUCTION_RESET=true RESET_CONFIRMATION=RESET-AUSTRALE-PRODUCCION RESET_ALL_LOYALTY=true npm run reset:production-data
 *
 * RPC (aplicar manualmente): scripts/sql/reset_production_transactional_data.sql
 */
import { createClient, type SupabaseClient } from "@supabase/supabase-js";
import { existsSync, readFileSync } from "node:fs";
import { resolve } from "node:path";

const REQUIRED_CONFIRMATION = "RESET-AUSTRALE-PRODUCCION";

const GENERIC_KIOSK_CATEGORY_NAMES = [
  "bebidas sin alcohol",
  "bebidas con alcohol",
  "comidas",
  "snacks",
  "combos",
  "merchandising",
  "otros",
];

type Env = Record<string, string | undefined>;

function loadEnvFile(path: string): Env {
  if (!existsSync(path)) return {};
  const out: Env = {};
  for (const line of readFileSync(path, "utf8").split(/\r?\n/)) {
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith("#")) continue;
    const idx = trimmed.indexOf("=");
    if (idx === -1) continue;
    out[trimmed.slice(0, idx).trim()] = trimmed.slice(idx + 1).trim();
  }
  return out;
}

function parseArgs(argv: string[]): { dryRun: boolean; resetAllLoyalty: boolean } {
  return {
    dryRun: argv.includes("--dry-run"),
    resetAllLoyalty:
      argv.includes("--reset-all-loyalty") ||
      process.env.RESET_ALL_LOYALTY === "true",
  };
}

function getEnv(): Env {
  return {
    ...loadEnvFile(resolve(process.cwd(), ".env.local")),
    ...process.env,
  };
}

function requireEnv(env: Env): { url: string; serviceKey: string } {
  const url = env.NEXT_PUBLIC_SUPABASE_URL;
  const serviceKey = env.SUPABASE_SERVICE_ROLE_KEY;
  if (!url || !serviceKey) {
    console.error(
      "Faltan NEXT_PUBLIC_SUPABASE_URL y/o SUPABASE_SERVICE_ROLE_KEY en .env.local",
    );
    process.exit(1);
  }
  return { url, serviceKey };
}

function assertRealRunAllowed(env: Env): void {
  if (env.ALLOW_PRODUCTION_RESET !== "true") {
    console.error(
      "Abortado: establecГ© ALLOW_PRODUCTION_RESET=true para ejecutar el reset real.",
    );
    process.exit(1);
  }
  if (env.RESET_CONFIRMATION !== REQUIRED_CONFIRMATION) {
    console.error(
      `Abortado: RESET_CONFIRMATION debe ser exactamente "${REQUIRED_CONFIRMATION}".`,
    );
    process.exit(1);
  }
}

async function countTable(
  admin: SupabaseClient,
  table: string,
): Promise<number | null> {
  const { count, error } = await admin
    .from(table)
    .select("*", { count: "exact", head: true });
  if (error) return null;
  return count ?? 0;
}

